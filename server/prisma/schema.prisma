generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  cards     CardMember[]
}

model Board {
  id         String   @id @default(uuid())
  title      String
  background String   @default("#0079bf")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lists      List[]
  labels     Label[]
}

model List {
  id        String   @id @default(uuid())
  title     String
  boardId   String
  order     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
}

model Card {
  id          String   @id @default(uuid())
  title       String
  description String?
  cover       String?
  listId      String
  order       Float
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  list        List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels      CardLabel[]
  members     CardMember[]
  checklists  Checklist[]
  comments    Comment[]
}

model Label {
  id      String   @id @default(uuid())
  title   String?
  color   String
  boardId String
  board   Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   CardLabel[]
}

model CardLabel {
  id      String @id @default(uuid())
  cardId  String
  labelId String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
}

model CardMember {
  id     String @id @default(uuid())
  cardId String
  userId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
}

model Checklist {
  id     String @id @default(uuid())
  title  String
  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items  ChecklistItem[]
}

model ChecklistItem {
  id          String  @id @default(uuid())
  content     String
  isCompleted Boolean @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(uuid())
  text        String
  createdAt   DateTime @default(now())
  authorName  String   @default("Demo User")
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}
